telegram:
  bot_token: "your_bot_token_here"
  chat_id: "your_chat_id_here"

poll_interval: 30       # 轮询间隔（秒）
forward_all: false      # true = 转发所有邮件+HTML附件；false = 只推验证码

# OAuth2 回调服务（用于 Outlook 一键授权）
oauth:
  enabled: true
  client_id: "your_azure_client_id"
  redirect_uri: "https://mail.idays.gq/api/emails/oauth/outlook/callback"
  port: 8080

accounts:
  - type: gmail
    mailboxes:
      - label: 我的Gmail
        email: you@gmail.com
        app_pass: "xxxx xxxx xxxx xxxx"
      - label: 备用Gmail
        email: backup@gmail.com
        app_pass: "xxxx xxxx xxxx xxxx"

  - type: qq
    mailboxes:
      - label: 我的QQ邮箱
        email: 123456@qq.com
        app_pass: "xxxxxxxxxxxxxxxx"

  - type: outlook
    mailboxes:
      - label: 我的Outlook
        email: you@hotmail.com
        refresh_token: "0.AXXX..."
        client_id: ""
